@model dynamic
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Slidify</title>
    <link rel="stylesheet" href="~/css/styles.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <style>
        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            background: var(--bg-color);
        }

        /* SIDEBAR */
        .dashboard-sidebar {
            width: 260px;
            background: var(--panel-bg);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            padding: 24px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }
        .sidebar-brand { font-size: 1.5rem; font-weight: 700; margin-bottom: 40px; display: flex; align-items: center; gap: 10px; }
        .sidebar-brand span {
            background: linear-gradient(to right, #818cf8, #c084fc);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .sidebar-nav { display: flex; flex-direction: column; gap: 8px; flex: 1; }
        .nav-item {
            padding: 12px 16px; border-radius: 10px; color: var(--text-muted); text-decoration: none;
            display: flex; align-items: center; gap: 12px; font-weight: 500; transition: 0.2s;
        }
        .nav-item:hover { background: var(--hover-bg); color: var(--text-main); }
        .nav-item.active { background: rgba(249, 115, 22, 0.15); color: var(--accent-orange); border-right: 3px solid var(--accent-orange); }
        .nav-item i { font-size: 1.1rem; width: 24px; }
        
        .user-profile {
            display: flex; align-items: center; gap: 12px; margin-top: auto; padding-top: 24px;
            border-top: 1px solid var(--border-color);
        }
        .avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; }
        .user-info h6 { margin: 0; font-size: 0.95rem; font-weight: 600; color: var(--text-main); }
        .user-info p { margin: 0; font-size: 0.8rem; color: var(--text-muted); }

        /* MAIN CONTENT */
        .dashboard-main { flex: 1; margin-left: 260px; padding: 40px; }
        
        .header-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        .search-bar { 
            position: relative; width: 300px;
        }
        .search-bar i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
        .search-bar input { width: 100%; padding: 12px 16px 12px 40px; border-radius: 12px; border: 1px solid var(--border-color); background: var(--input-bg); color: var(--text-main); font-family: 'Inter', sans-serif;}
        .search-bar input:focus { border-color: var(--primary); outline: none; }

        /* BANNER */
        .welcome-banner {
            background: linear-gradient(135deg, rgba(249, 115, 22, 0.8), rgba(234, 179, 8, 0.8));
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px; padding: 40px; margin-bottom: 40px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 10px 30px rgba(249, 115, 22, 0.2);
        }
        .banner-text h1 { font-size: 2.2rem; font-weight: 700; margin-bottom: 12px; color: white; }
        .banner-text p { color: rgba(255,255,255,0.9); font-size: 1.05rem; margin-bottom: 24px; }
        
        /* TEMPLATES */
        .section-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 20px; }
        .template-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .template-card {
            background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 16px;
            cursor: pointer; transition: 0.3s; text-align: center; text-decoration: none; display: block;
        }
        .template-card:hover { transform: translateY(-4px); border-color: var(--primary); box-shadow: 0 10px 20px -10px rgba(99, 102, 241, 0.3); }
        .template-card.active {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.08);
            box-shadow: 0 10px 20px -10px rgba(99, 102, 241, 0.3);
            transform: translateY(-2px);
        }
        .template-card h5 { color: var(--text-main); margin: 0; font-size: 1rem; font-weight: 600; }
        .template-icon { width: 60px; height: 60px; background: rgba(99, 102, 241, 0.1); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 16px; transition: 0.3s; }
        .template-card.active .template-icon { transform: scale(1.05); }
        
        /* PROJECTS */
        .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
        .project-card {
            background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 16px;
            overflow: hidden; transition: 0.3s; position: relative;
        }
        .project-card:hover { transform: translateY(-4px); box-shadow: var(--glass-shadow); border-color: var(--border-color); }
        .project-thumb { width: 100%; aspect-ratio: 16/9; background: #e2e8f0; object-fit: cover; }
        .project-info { padding: 16px; }
        .project-title { font-weight: 600; font-size: 1.05rem; margin-bottom: 4px; color: var(--text-main); text-decoration: none; display: block; }
        .project-title:hover { color: var(--primary); }
        .project-meta { font-size: 0.85rem; color: var(--text-muted); }
        
        .project-actions { position: absolute; top: 12px; right: 12px; opacity: 0; transition: 0.2s; display: flex; gap: 8px; }
        .project-card:hover .project-actions { opacity: 1; }
        .btn-action { background: rgba(15, 23, 42, 0.6); color: white; border: 1px solid rgba(255,255,255,0.1); width: 36px; height: 36px; border-radius: 10px; cursor: pointer; backdrop-filter: blur(8px); transition: 0.2s; }
        .btn-action:hover { background: var(--accent-orange); border-color: var(--accent-orange); transform: translateY(-2px); }
        
        /* TOAST */
        #toast-container { position: fixed; bottom: 30px; right: 30px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
        .toast { background: rgba(15,23,42,0.9); backdrop-filter: blur(10px); color: white; padding: 16px 24px; border-radius: 12px; border-left: 4px solid var(--accent-orange); box-shadow: 0 10px 25px rgba(0,0,0,0.2); font-weight: 500; transform: translateX(120%); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; align-items: center; gap: 12px; }
        .toast.show { transform: translateX(0); }
        .toast i { font-size: 1.2rem; color: var(--accent-orange); }

        /* RECENT DESIGNS - Canva Style */
        .recent-section { margin-bottom: 40px; }
        .recent-scroll-container {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            padding-bottom: 12px;
            scroll-behavior: smooth;
            -ms-overflow-style: none;
            scrollbar-width: thin;
            scrollbar-color: rgba(148, 163, 184, 0.3) transparent;
        }
        .recent-scroll-container::-webkit-scrollbar { height: 6px; }
        .recent-scroll-container::-webkit-scrollbar-track { background: transparent; }
        .recent-scroll-container::-webkit-scrollbar-thumb { background: rgba(148, 163, 184, 0.3); border-radius: 10px; }
        .recent-scroll-container::-webkit-scrollbar-thumb:hover { background: rgba(148, 163, 184, 0.5); }

        .recent-card {
            flex: 0 0 220px;
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            cursor: pointer;
            text-decoration: none;
            display: block;
        }
        .recent-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
            box-shadow: 0 12px 28px -8px rgba(99, 102, 241, 0.25);
        }
        .recent-card-thumb {
            width: 100%;
            aspect-ratio: 16/9;
            object-fit: cover;
            display: block;
        }
        .recent-card-placeholder {
            width: 100%;
            aspect-ratio: 16/9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: rgba(148, 163, 184, 0.5);
        }
        .recent-card-info {
            padding: 12px 14px;
        }
        .recent-card-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 4px;
        }
        .recent-card-meta {
            font-size: 0.78rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .recent-card-badge {
            position: absolute;
            bottom: 60px;
            right: 8px;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(6px);
            color: white;
            font-size: 0.7rem;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 12px;
        }
        .recent-card-actions {
            position: absolute;
            top: 8px;
            right: 8px;
            display: flex;
            gap: 6px;
            opacity: 0;
            transition: opacity 0.2s;
        }
        .recent-card:hover .recent-card-actions { opacity: 1; }
        .recent-card-actions .btn-action {
            width: 30px; height: 30px;
            font-size: 0.8rem;
            border-radius: 8px;
        }
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }
        .section-header h2 { margin: 0; }
    </style>
</head>
<body class="dark-mode">
    <div id="toast-container"></div>
    <div class="dashboard-layout">
        <!-- SIDEBAR -->
        <aside class="dashboard-sidebar">
            <div class="sidebar-brand">
                <i class="fa-solid fa-layer-group" style="color: var(--primary)"></i>
                <span>Slidify</span>
            </div>
            
            <nav class="sidebar-nav">
                <a href="#" class="nav-item active"><i class="fa-solid fa-folder-open"></i> Dự án của tôi</a>
                <a href="#" class="nav-item" onclick="showDevToast('Tính năng Chia sẻ đang phát triển!')"><i class="fa-solid fa-users"></i> Được chia sẻ</a>
                <a href="#" class="nav-item" onclick="showDevToast('Tính năng Quản lý mẫu đang phát triển!')"><i class="fa-solid fa-wand-magic-sparkles"></i> Mẫu thiết kế</a>
                <a href="#" class="nav-item" onclick="showDevToast('Tính năng Thùng rác đang phát triển!')"><i class="fa-solid fa-trash-can"></i> Thùng rác</a>
            </nav>

            <div class="user-profile">
                <div class="avatar">@User.Identity?.Name?.Substring(0,1).ToUpper()</div>
                <div class="user-info">
                    <h6>@User.Identity?.Name</h6>
                    <p>Thành viên Pro</p>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin-left: auto;">
                    <button type="submit" class="btn-icon" title="Đăng xuất"><i class="fa-solid fa-right-from-bracket"></i></button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="dashboard-main">
            <div class="header-actions">
                <div class="search-bar">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Tìm kiếm dự án..." value="@Model.SearchQuery" onkeypress="if(event.key==='Enter') window.location.href='/Home/Index?search=' + encodeURIComponent(this.value)" />
                </div>
                <button class="btn-success" style="padding: 12px 24px; font-size: 1rem; background: linear-gradient(135deg, var(--accent-orange), var(--accent-yellow)); border:none; box-shadow: 0 4px 15px rgba(249, 115, 22, 0.3);" onclick="showDevToast('Tính năng Nâng cấp Pro đang phát triển!')"><i class="fa-solid fa-crown"></i> Nâng cấp Pro</button>
            </div>

            <!-- BANNER -->
            <div class="welcome-banner">
                <div class="banner-text">
                    <h1>Sáng tạo không giới hạn</h1>
                    <p>Thiết kế những bản thuyết trình tuyệt đẹp chỉ trong vài phút.</p>
                    
                    <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                        <form id="create-form" asp-controller="Slide" asp-action="Create" method="post" style="display: inline-block; margin: 0;">
                            <button type="submit" class="btn-success" style="padding: 14px 28px; font-size: 1.05rem; background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4); color: white;">
                                <i class="fa-solid fa-plus"></i> Tạo bản thuyết trình mới
                            </button>
                        </form>
                        <input type="file" id="import-pdf-input" accept="application/pdf" style="display:none;" onchange="importPDF(event)" />
                        <button type="button" class="btn-success" style="padding: 14px 28px; font-size: 1.05rem; background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.4); color: white;" onclick="document.getElementById('import-pdf-input').click()">
                            <i class="fa-solid fa-file-pdf"></i> Nhập & Chỉnh sửa PDF (Mới)
                        </button>
                    </div>
                </div>
                <img src="https://illustrations.popsy.co/amber/keynote-presentation.svg" alt="Illustration" style="height: 200px;">
            </div>

            <!-- TEMPLATES -->
            <h2 class="section-title">Bắt đầu nhanh với mẫu</h2>
            <div class="template-grid" style="margin-bottom: 20px;">
                <a href="/Home/Index?category=Doanh nghiệp" class="template-card @(Model.ActiveCategory == "Doanh nghiệp" ? "active" : "")">
                    <div class="template-icon" style="color: #f97316; background: rgba(249,115,22,0.1)"><i class="fa-solid fa-briefcase"></i></div>
                    <h5>Doanh nghiệp</h5>
                </a>
                <a href="/Home/Index?category=Giáo dục" class="template-card @(Model.ActiveCategory == "Giáo dục" ? "active" : "")">
                    <div class="template-icon" style="color: #10b981; background: rgba(16,185,129,0.1)"><i class="fa-solid fa-graduation-cap"></i></div>
                    <h5>Giáo dục</h5>
                </a>
                <a href="/Home/Index?category=Công nghệ" class="template-card @(Model.ActiveCategory == "Công nghệ" ? "active" : "")">
                    <div class="template-icon" style="color: #3b82f6; background: rgba(59,130,246,0.1)"><i class="fa-solid fa-laptop-code"></i></div>
                    <h5>Công nghệ</h5>
                </a>
                <a href="/Home/Index?category=Sáng tạo" class="template-card @(Model.ActiveCategory == "Sáng tạo" ? "active" : "")">
                    <div class="template-icon" style="color: #ec4899; background: rgba(236,72,153,0.1)"><i class="fa-solid fa-palette"></i></div>
                    <h5>Sáng tạo</h5>
                </a>
            </div>

            <!-- GẦN ĐÂY - Canva Style Recent Designs -->
            @{
                var recentProjects = ((IEnumerable<DoAnLtWeb.Models.Presentation>)Model.MyProjects).Take(10).ToList();
            }
            @if (recentProjects.Any())
            {
                <div class="recent-section">
                    <div class="section-header">
                        <h2 class="section-title" style="margin-bottom:0;">Gần đây</h2>
                        <a href="#my-projects-section" style="color: var(--primary); font-size: 0.9rem; font-weight: 600; text-decoration: none;">Xem tất cả <i class="fa-solid fa-arrow-right" style="font-size:0.75rem;"></i></a>
                    </div>
                    <div class="recent-scroll-container">
                        @foreach (var item in recentProjects)
                        {
                            var firstSlide = item.Slides?.OrderBy(s => s.PageNumber).FirstOrDefault();
                            var slideCount = item.Slides?.Count ?? 0;
                            <a href="/Slide/Edit/@item.Id" class="recent-card">
                                <div class="recent-card-actions">
                                    <button class="btn-action" title="Nhân bản" onclick="event.preventDefault(); event.stopPropagation(); duplicateProject(@item.Id)"><i class="fa-solid fa-copy"></i></button>
                                    <button class="btn-action" style="background: rgba(239, 68, 68, 0.8); border-color: rgba(239, 68, 68, 0.8);" title="Xóa" onclick="event.preventDefault(); event.stopPropagation(); deleteProject(@item.Id)"><i class="fa-solid fa-trash"></i></button>
                                </div>
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" class="recent-card-thumb" alt="@item.Title" />
                                }
                                else if (firstSlide != null && !string.IsNullOrEmpty(firstSlide.BackgroundImage))
                                {
                                    <img src="@firstSlide.BackgroundImage" class="recent-card-thumb" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="recent-card-placeholder" style="background: @(firstSlide?.BackgroundColor ?? "#1e293b");">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                }
                                @if (slideCount > 0)
                                {
                                    <span class="recent-card-badge">@slideCount trang</span>
                                }
                                <div class="recent-card-info">
                                    <div class="recent-card-title">@item.Title</div>
                                    <div class="recent-card-meta">
                                        <i class="fa-solid fa-clock" style="font-size:0.7rem;"></i>
                                        @{
                                            var timeDiff = DateTime.UtcNow - item.UpdatedAt;
                                            string timeAgo;
                                            if (timeDiff.TotalMinutes < 1) timeAgo = "Vừa xong";
                                            else if (timeDiff.TotalMinutes < 60) timeAgo = $"Đã sửa {(int)timeDiff.TotalMinutes} phút trước";
                                            else if (timeDiff.TotalHours < 24) timeAgo = $"Đã sửa {(int)timeDiff.TotalHours} giờ trước";
                                            else if (timeDiff.TotalDays < 30) timeAgo = $"Đã sửa {(int)timeDiff.TotalDays} ngày trước";
                                            else timeAgo = $"Đã sửa {item.UpdatedAt:dd/MM/yyyy}";
                                        }
                                        @timeAgo
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- TEMPLATES -->
            @if (Model.Templates != null && ((IEnumerable<DoAnLtWeb.Models.Presentation>)Model.Templates).Any())
            {
                <h2 class="section-title">Mẫu thiết kế</h2>
                <div class="project-grid" style="margin-bottom: 40px; padding-top: 10px; border-top: 1px solid var(--border-color);">
                    @foreach (var tpl in Model.Templates)
                    {
                        <div class="project-card" style="border-color: rgba(16, 185, 129, 0.4);">
                            <div class="project-actions">
                                <form asp-controller="Slide" asp-action="CloneTemplate" asp-route-id="@tpl.Id" method="post">
                                    <button type="submit" class="btn-action" style="width: auto; padding: 0 12px; background: var(--success); border-color: var(--success); font-size: 0.85rem;"><i class="fa-solid fa-magic"></i> Tạo từ mẫu</button>
                                </form>
                            </div>
                            <div style="cursor: default;">
                                @if (!string.IsNullOrEmpty(tpl.ThumbnailUrl))
                                {
                                    <img src="@tpl.ThumbnailUrl" class="project-thumb" alt="@tpl.Title" />
                                }
                                else
                                {
                                    string bgColor = tpl.Category switch {
                                        "Doanh nghiệp" => "linear-gradient(135deg, #1e3a8a, #3b82f6)",
                                        "Giáo dục" => "linear-gradient(135deg, #166534, #fcd34d)",
                                        "Công nghệ" => "linear-gradient(135deg, #000000, #c026d3)",
                                        "Sáng tạo" => "linear-gradient(135deg, #ec4899, #f97316)",
                                        _ => "linear-gradient(135deg, #475569, #94a3b8)"
                                    };
                                    <div class="project-thumb" style="display:flex; flex-direction:column; align-items:center; justify-content:center; background:@bgColor; color:white; padding: 20px; text-align:center;">
                                        <i class="fa-solid fa-palette fa-2x" style="opacity:0.8; margin-bottom: 12px;"></i>
                                        <span style="font-weight:bold; font-size:1.2rem; font-family:'Inter'; text-shadow: 1px 1px 4px rgba(0,0,0,0.4); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">@tpl.Title</span>
                                    </div>
                                }
                            </div>
                            <div class="project-info">
                                <span class="project-title">@tpl.Title</span>
                                <div class="project-meta">Mẫu @tpl.Category</div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- MY PROJECTS -->
            <h2 class="section-title" id="my-projects-section">Tất cả dự án</h2>
            <div class="project-grid">
                @if (!((IEnumerable<DoAnLtWeb.Models.Presentation>)Model.MyProjects).Any())
                {
                    <p class="text-muted">Bạn chưa có bản thuyết trình nào. Hãy tạo mới ngay!</p>
                }
                else
                {
                    foreach (var item in Model.MyProjects)
                    {
                        <div class="project-card">
                            <div class="project-actions">
                                <button class="btn-action" title="Nhân bản" onclick="duplicateProject(@item.Id)"><i class="fa-solid fa-copy"></i></button>
                                <button class="btn-action" style="background: rgba(239, 68, 68, 0.8); border-color: rgba(239, 68, 68, 0.8);" title="Xóa" onclick="deleteProject(@item.Id)"><i class="fa-solid fa-trash"></i></button>
                            </div>
                            <a href="/Slide/Edit/@item.Id">
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" class="project-thumb" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="project-thumb" style="display:flex; align-items:center; justify-content:center; background:#1e293b; color:#94a3b8; font-size:2rem;">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                }
                            </a>
                            <div class="project-info">
                                <a href="/Slide/Edit/@item.Id" class="project-title">@item.Title</a>
                                <div class="project-meta">Cập nhật: @item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </main>
    </div>
    <script>
        function showDevToast(message) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `<i class="fa-solid fa-circle-info"></i> <span>${message}</span>`;
            
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => toast.classList.add('show'), 10);
            
            // Remove after 3s
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        async function duplicateProject(id) {
            if(!confirm("Bạn có chắc chắn muốn nhân bản dự án này?")) return;
            try {
                const response = await fetch(`/Slide/Duplicate/${id}`, { method: 'POST' });
                if(response.ok) {
                    showDevToast('Đã nhân bản dự án thành công!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showDevToast('Lỗi khi nhân bản dự án!');
                }
            } catch(e) {
                showDevToast('Lỗi kết nối!');
            }
        }

        async function deleteProject(id) {
            if(!confirm("Bạn có chắc chắn muốn xóa dự án này?")) return;
            try {
                const response = await fetch(`/Slide/Delete/${id}`, { method: 'POST' });
                if(response.ok) {
                    showDevToast('Đã xóa dự án thành công!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showDevToast('Lỗi khi xóa dự án!');
                }
            } catch(e) {
                showDevToast('Lỗi kết nối!');
            }
        }

        async function importPDF(event) {
            const file = event.target.files[0];
            if (!file) return;

            showDevToast('Khởi tạo trình phân tích PDF...');

            // Cấu hình worker cho PDF.js
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

            try {
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                const totalPages = pdf.numPages;

                showDevToast(`Đọc thành công ${totalPages} trang. Bắt đầu chuyển đổi...`);

                const slidesArray = [];

                for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
                    showDevToast(`Đang phân tích trang ${pageNum} / ${totalPages}...`);
                    const page = await pdf.getPage(pageNum);

                    // 1. Render trang PDF làm ảnh nền (Độ phân giải cao 2x)
                    const viewport = page.getViewport({ scale: 1.0 });
                    const canvas = document.createElement('canvas');
                    canvas.width = viewport.width * 2.0;
                    canvas.height = viewport.height * 2.0;
                    const context = canvas.getContext('2d');

                    await page.render({ 
                        canvasContext: context, 
                        viewport: page.getViewport({ scale: 2.0 }) 
                    }).promise;

                    // Upload ảnh nền này lên Backend
                    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.85));
                    const formData = new FormData();
                    formData.append("file", blob, `pdf_page_${pageNum}.jpg`);

                    const uploadResponse = await fetch('/Slide/UploadImage', {
                        method: 'POST',
                        body: formData
                    });

                    let bgUrl = "";
                    if (uploadResponse.ok) {
                        const uploadData = await uploadResponse.json();
                        bgUrl = uploadData.url;
                    }

                    // 2. Trích xuất Text để tạo các đối tượng chữ IText có thể sửa được
                    const textContent = await page.getTextContent();
                    const textObjects = [];

                    // Khổ canvas chuẩn Slidify: 800 x 450
                    const standardWidth = 800;
                    const standardHeight = 450;

                    // Tỉ lệ scale tọa độ chuẩn
                    const scaleX = standardWidth / viewport.width;
                    const scaleY = standardHeight / viewport.height;

                    textContent.items.forEach((item) => {
                        if (!item.str.trim()) return;

                        // Tọa độ X chuẩn
                        const tx = item.transform[4] * scaleX;

                        // Chiều cao chữ trong PDF space (sử dụng item.height hoặc từ transform làm fallback)
                        let fontHeightPDF = item.height;
                        if (!fontHeightPDF || fontHeightPDF <= 0) {
                            fontHeightPDF = Math.abs(item.transform[3]) || Math.abs(item.transform[0]) || 12;
                        }

                        // Tính size chữ tương ứng chính xác dựa trên tỉ lệ màn hình
                        const fontSize = Math.max(8, Math.min(100, Math.round(fontHeightPDF * scaleY)));

                        // Tọa độ Y chuẩn xác: baseline Y - fontHeightPDF
                        const ty = (viewport.height - item.transform[5] - fontHeightPDF) * scaleY;

                        textObjects.push({
                            type: 'i-text',
                            version: '5.3.0',
                            originX: 'left',
                            originY: 'top',
                            left: Math.round(tx),
                            top: Math.round(ty),
                            width: Math.round(item.width * scaleX),
                            height: Math.round(item.height * scaleY),
                            fill: '#333333',
                            fontFamily: 'Inter',
                            fontSize: fontSize,
                            fontWeight: 'normal',
                            fontStyle: 'normal',
                            underline: false,
                            strikethrough: false,
                            text: item.str,
                            id: Math.random().toString(36).substr(2, 9),
                            name: item.str.substring(0, 10) + '...',
                            selectable: true
                        });
                    });

                    slidesArray.push({
                        PageNumber: pageNum,
                        BackgroundColor: '#ffffff',
                        BackgroundImage: bgUrl,
                        ElementsJson: JSON.stringify({
                            version: '5.3.0',
                            objects: textObjects
                        })
                    });
                }

                showDevToast('Đang khởi tạo dự án thuyết trình mới...');

                // Gọi C# API CreateFromImport
                const createResponse = await fetch('/Slide/CreateFromImport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        Title: file.name.replace(/\.[^/.]+$/, ""), // Bỏ đuôi .pdf
                        Slides: slidesArray
                    })
                });

                if (createResponse.ok) {
                    const data = await createResponse.json();
                    showDevToast('Chuyển đổi PDF thành công! Đang vào trình biên soạn...');
                    setTimeout(() => {
                        window.location.href = `/Slide/Edit/${data.id}`;
                    }, 1000);
                } else {
                    showDevToast('Lỗi lưu trữ bản thuyết trình nhập từ PDF!');
                }

            } catch (err) {
                console.error("PDF Import error:", err);
                showDevToast('Có lỗi xảy ra khi nhập file PDF này!');
            }
        }
    </script>
</body>
