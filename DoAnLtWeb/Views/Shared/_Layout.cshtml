@inject Microsoft.AspNetCore.Identity.UserManager<DoAnLtWeb.Models.User> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var isVipUser = appUser?.IsVip ?? false;
    var isAdminUser = User.IsInRole("Admin") || appUser?.Email == "admin@gmail.com";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Slidify</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0b0f19;
            --panel-bg: rgba(17, 24, 39, 0.75);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --accent-orange: #f97316;
        }
        html { background-color: var(--bg-color); }
        body {
            background-color: var(--bg-color) !important;
            color: var(--text-main) !important;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .navbar {
            background: rgba(15, 23, 42, 0.8) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color) !important;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            color: #fff !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .navbar-brand span {
            background: linear-gradient(to right, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            transition: 0.2s;
        }
        .nav-link:hover, .nav-link.active {
            color: #fff !important;
        }
        .footer {
            flex-shrink: 0;
            background: rgba(15, 23, 42, 0.9) !important;
            border-top: 1px solid var(--border-color) !important;
            color: var(--text-muted) !important;
            padding: 20px 0;
            margin-top: 40px;
        }
        .role-badge {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .role-admin { background: #ef4444; color: #fff; }
        .role-vip { background: #8b5cf6; color: #fff; }
        .role-user { background: #6b7280; color: #fff; }
    </style>
</head>
<body class="dark-mode">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-layer-group" style="color: var(--primary)"></i>
                    <span>Slidify</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @if (isAdminUser)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Quản trị Admin</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-white font-weight-600">
                                Xin chào, @(appUser?.Username ?? User.Identity.Name)
                                @if (isAdminUser)
                                {
                                    <span class="role-badge role-admin"><i class="fa-solid fa-user-shield"></i> Admin</span>
                                }
                                else if (isVipUser)
                                {
                                    <span class="role-badge role-vip"><i class="fa-solid fa-crown"></i> VIP</span>
                                }
                                else
                                {
                                    <span class="role-badge role-user"><i class="fa-solid fa-user"></i> User</span>
                                }
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius:8px; border-color: rgba(239, 68, 68, 0.4);"><i class="fa-solid fa-right-from-bracket"></i> Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-primary btn-sm px-3" style="border-radius:8px;">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container" style="flex:1 0 auto;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Slidify - Nền tảng thiết kế Slide chất lượng cao
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
