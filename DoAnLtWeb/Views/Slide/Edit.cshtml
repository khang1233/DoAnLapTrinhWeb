@model DoAnLtWeb.Models.Presentation

@{
    ViewData["Title"] = Model.Title;
    Layout = null; // Use a standalone layout for the editor (Canva-like full screen)
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title - Slidify Editor</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Montserrat:wght@400;700&family=Playfair+Display:wght@700&family=Oswald:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css?v=2">
    <!-- Fabric.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
    <!-- jsPDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body class="dark-mode">

    <!-- Store Presentation Data for JS -->
    <input type="hidden" id="presentation-id" value="@Model.Id" />
    <input type="hidden" id="presentation-data" value='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Slides.Select(s => new { s.PageNumber, s.BackgroundColor, s.BackgroundImage, s.ElementsJson })))' />

    <!-- Editor Section (Canva/PowerPoint Clone) -->
    <div id="editor-section" style="display: flex; flex-direction: column; height: 100vh;">
        <!-- Top Toolbar -->
        <div class="editor-topbar">
            <div class="editor-topbar-title">
                <a href="/Home/Index" class="btn-icon" style="text-decoration:none;"><i class="fa-solid fa-arrow-left"></i></a>
                <span id="current-project-name" contenteditable="true">@Model.Title</span>
                <span id="save-status" class="text-muted" style="font-size: 0.8rem; margin-left: 10px;"><i class="fa-solid fa-cloud-check"></i> Đã lưu</span>
            </div>
            <div class="editor-topbar-tools">
                @if (User.Identity.Name == "Admin" || User.Identity.Name == "admin" || User.Claims.Any(c => c.Value == "admin@slidify.com"))
                {
                    <button onclick="publishAsTemplate()" class="btn-icon" style="color: #f59e0b;" title="Dành cho Admin"><i class="fa-solid fa-crown"></i> Đăng làm Mẫu</button>
                }
                <!-- AI Generation Placeholder -->
                <button onclick="generateWithAI()" class="btn-icon" style="color: #a855f7;" title="Thiết kế bằng AI (Đang phát triển)"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Design</button>
                
                <button onclick="resizeCanvasPrompt()" class="btn-icon" title="Đổi kích thước Slide"><i class="fa-solid fa-expand"></i> Resize</button>
                <button onclick="showToast('Tính năng Trình chiếu đang phát triển!', 'info')" class="btn-icon"><i class="fa-solid fa-play"></i> Trình bày</button>
                <button onclick="showToast('Tính năng Chia sẻ đang phát triển!', 'info')" class="btn-icon"><i class="fa-solid fa-share-nodes"></i> Chia sẻ</button>
                <button onclick="savePresentationManually()" class="btn-success"><i class="fa-solid fa-floppy-disk"></i> Lưu</button>
                <button onclick="exportToImage()" class="btn-icon"><i class="fa-solid fa-image"></i> Tải ảnh</button>
                <button onclick="exportToPDF()" class="btn-icon"><i class="fa-solid fa-file-pdf"></i> Tải PDF</button>
            </div>
        </div>

        <!-- Canva Style Sub-toolbar (Properties) -->
        <div class="editor-sub-toolbar" id="sub-toolbar" style="visibility: hidden;">
            <div class="prop-group" id="prop-font-group">
                <select id="prop-font-family" onchange="updateObjectProperty('fontFamily', this.value)">
                    <option value="Inter">Inter</option>
                    <option value="Montserrat">Montserrat</option>
                    <option value="Playfair Display">Playfair Display</option>
                    <option value="Oswald">Oswald</option>
                    <option value="Arial">Arial</option>
                    <option value="Times New Roman">Times New Roman</option>
                </select>
                <input type="number" id="prop-font-size" onchange="updateObjectProperty('fontSize', this.value)" min="10" max="200" title="Cỡ chữ">
                <input type="color" id="prop-color" onchange="updateObjectProperty('fill', this.value)" title="Màu chữ" style="width: 30px; height: 30px; padding: 0; border: none; cursor: pointer; background: transparent;">
                <button class="btn-format" id="btn-bold" onclick="toggleFormat('fontWeight', 'bold', 'normal')" title="In đậm (Ctrl+B)"><b>B</b></button>
                <button class="btn-format" id="btn-italic" onclick="toggleFormat('fontStyle', 'italic', 'normal')" title="In nghiêng (Ctrl+I)"><i>I</i></button>
                <button class="btn-format" id="btn-underline" onclick="toggleFormat('underline', true, false)" title="Gạch chân (Ctrl+U)"><u>U</u></button>
                <button class="btn-format" id="btn-strikethrough" onclick="toggleFormat('linethrough', true, false)" title="Gạch ngang">S</button>
                <button class="btn-format" id="btn-uppercase" onclick="toggleUppercase()" title="Chữ hoa">aA</button>
                <button class="btn-format" id="btn-align-left" onclick="updateObjectProperty('textAlign', 'left')"><i class="fa-solid fa-align-left"></i></button>
                <button class="btn-format" id="btn-align-center" onclick="updateObjectProperty('textAlign', 'center')"><i class="fa-solid fa-align-center"></i></button>
                <button class="btn-format" id="btn-align-right" onclick="updateObjectProperty('textAlign', 'right')"><i class="fa-solid fa-align-right"></i></button>
                
                <label title="Khoảng cách dòng" style="margin-left: 10px;"><i class="fa-solid fa-arrows-up-down"></i></label>
                <input type="range" id="prop-line-height" min="0.5" max="3" step="0.1" value="1.16" oninput="updateObjectProperty('lineHeight', this.value)" style="width: 60px;">
            </div>
            <div class="prop-group" id="prop-shape-group" style="display:none;">
                <label title="Màu tô (Fill)"><i class="fa-solid fa-fill"></i></label>
                <input type="color" id="prop-fill-color" onchange="updateObjectProperty('fill', this.value)">
                
                <label title="Màu viền (Stroke)" style="margin-left: 10px;"><i class="fa-solid fa-pen-fancy"></i></label>
                <input type="color" id="prop-stroke-color" onchange="updateObjectProperty('stroke', this.value)">
                
                <label title="Độ dày viền (Stroke Width)" style="margin-left: 10px;"><i class="fa-solid fa-border-none"></i></label>
                <input type="number" id="prop-stroke-width" min="0" max="50" onchange="updateObjectProperty('strokeWidth', this.value)">
            </div>
            
            <div class="prop-group">
                <label title="Bóng đổ (Shadow)"><i class="fa-solid fa-moon"></i></label>
                <input type="checkbox" id="prop-shadow" onchange="toggleShadow(this.checked)">

                <label title="Độ trong suốt (Opacity)" style="margin-left: 10px;"><i class="fa-solid fa-chess-board"></i></label>
                <input type="range" id="prop-opacity" class="range-slider" min="0" max="1" step="0.05" value="1" oninput="updateObjectProperty('opacity', this.value)" style="width: 80px;">
            </div>
            <div class="prop-group">
                <button class="btn-icon" onclick="bringForward()" title="Lên trên"><i class="fa-solid fa-arrow-up-long"></i> Lên trên</button>
                <button class="btn-icon" onclick="sendBackward()" title="Xuống dưới"><i class="fa-solid fa-arrow-down-long"></i> Xuống dưới</button>
                <button class="btn-icon" style="color:var(--danger)" onclick="deleteSelected()" title="Xóa"><i class="fa-solid fa-trash"></i> Xóa</button>
            </div>
        </div>

        <div class="editor-workspace" style="flex: 1; display: flex; overflow: hidden;">
            <!-- Left Sidebar (Canva Tools) -->
            <div class="editor-sidebar">
                <div class="sidebar-tool" id="tab-design" onclick="toggleDrawer('design')" title="Mẫu">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    <span>Mẫu</span>
                </div>
                <div class="sidebar-tool" id="tab-elements" onclick="toggleDrawer('elements')" title="Thành phần">
                    <i class="fa-solid fa-shapes"></i>
                    <span>Thành phần</span>
                </div>
                <div class="sidebar-tool" id="tab-text" onclick="toggleDrawer('text')" title="Văn bản">
                    <i class="fa-solid fa-font"></i>
                    <span>Văn bản</span>
                </div>
                <div class="sidebar-tool" id="tab-photos" onclick="toggleDrawer('photos')" title="Ảnh (Mới)">
                    <i class="fa-solid fa-image"></i>
                    <span>Ảnh</span>
                </div>
                <div class="sidebar-tool" id="tab-bg" onclick="toggleDrawer('bg')" title="Nền (Mới)">
                    <i class="fa-solid fa-fill-drip"></i>
                    <span>Nền</span>
                </div>
                <div class="sidebar-tool" id="tab-upload" onclick="toggleDrawer('upload')" title="Tải lên">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <span>Tải lên</span>
                </div>
                <input type="file" id="upload-img-input" accept="image/png, image/jpeg, image/svg+xml" class="hidden" onchange="uploadImageReal(event)">
                <div class="sidebar-tool" id="tab-draw" onclick="toggleDrawer('draw')" title="Vẽ">
                    <i class="fa-solid fa-pen-nib"></i>
                    <span>Vẽ</span>
                </div>
            </div>

            <!-- Drawer Panel -->
            <div class="editor-drawer" id="drawer-panel">
                <!-- Content gets injected by JS -->
            </div>

            <!-- Main Canvas & Bottom Thumbnails Area -->
            <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
                <!-- Main Canvas -->
                <div class="editor-canvas-container" id="canvas-container">
                    <div class="canvas-wrapper">
                        <!-- Default 16:9 ratio -->
                        <canvas id="canvas" width="800" height="450"></canvas>
                    </div>
                </div>

                <!-- Bottom Slide Panel (Canva Style) -->
                <div class="editor-bottom-thumbnails">
                    <div id="slides-list" class="slides-list-horizontal">
                        <!-- Slide Thumbnails go here -->
                    </div>
                    <button class="btn-add-slide-horizontal" onclick="addNewSlide()" title="Thêm trang mới">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </div>
            </div>
            <!-- /End Canvas + Thumbnails column -->

            <!-- Context Menu -->
            <div id="context-menu" class="custom-context-menu">
                <div class="context-menu-item" onclick="contextAction('copy')">
                    <i class="fa-regular fa-copy"></i> Sao chép <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted)">Ctrl+C</span>
                </div>
                <div class="context-menu-item" onclick="contextAction('paste')">
                    <i class="fa-regular fa-paste"></i> Dán <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted)">Ctrl+V</span>
                </div>
                <div class="context-menu-item" onclick="contextAction('duplicate')">
                    <i class="fa-regular fa-clone"></i> Tạo bản sao <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted)">Ctrl+D</span>
                </div>
                <div class="context-divider"></div>
                <div class="context-menu-item has-submenu">
                    <i class="fa-solid fa-layer-group"></i> Lớp
                    <i class="fa-solid fa-chevron-right" style="margin-left:auto; font-size: 0.75rem"></i>
                    <div class="context-submenu">
                        <div class="context-menu-item" onclick="contextAction('bringForward')"><i class="fa-solid fa-angle-up"></i> Tiến một lớp</div>
                        <div class="context-menu-item" onclick="contextAction('bringToFront')"><i class="fa-solid fa-angles-up"></i> Lên trước</div>
                        <div class="context-menu-item" onclick="contextAction('sendBackward')"><i class="fa-solid fa-angle-down"></i> Lùi một lớp</div>
                        <div class="context-menu-item" onclick="contextAction('sendToBack')"><i class="fa-solid fa-angles-down"></i> Xuống cuối</div>
                    </div>
                </div>
                <div class="context-divider"></div>
                <div class="context-menu-item" onclick="contextAction('lock')" id="context-btn-lock">
                    <i class="fa-solid fa-lock"></i> Khóa
                </div>
                <div class="context-divider"></div>
                <div class="context-menu-item" onclick="contextAction('addPage')">
                    <i class="fa-solid fa-plus"></i> Thêm trang
                </div>
                <div class="context-menu-item" onclick="contextAction('delete')" style="color:var(--danger)">
                    <i class="fa-solid fa-trash"></i> Xóa
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast">Message here</div>

    <!-- Real-time Collaboration Placeholder -->
    <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script> -->
    <!-- <script>
        // const connection = new signalR.HubConnectionBuilder().withUrl("/slideHub").build();
        // connection.on("ReceiveSlideUpdate", (data) => { /* Update canvas */ });
        // connection.start().catch(err => console.error(err.toString()));
    </script> -->

    <script src="~/js/slide-editor.js"></script>
</body>
</html>
